{
  "files.exclude": {
    "**/.git": true,
    "**/.vscode": true,
    "**/.idea": true,
    "**/.cursor": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/*.log": true,
    "**/*.tmp": true,
    "**/*.bak": true,
    "**/*.swp": true,
    "**/*.swo": true,
    "**/.env": true,
    "**/.env.local": true,
    "**/.env.*.local": true,
    "**/*.pem": true,
    "**/*.key": true,
    "**/*.cert": true,
    "**/*.crseo": true,
    "**/creds/": true,
    "**/secrets/": true,
    "**/__pycache__/": true,
    "**/*.py[cod]": true,
    "**/*$py.class": true,
    "**/*.so": true,
    "**/.Python": true,
    "**/build/": true,
    "**/develop-eggs/": true,
    "**/dist/": true,
    "**/downloads/": true,
    "**/eggs/": true,
    "**/.eggs/": true,
    "**/lib/": true,
    "**/lib64/": true,
    "**/parts/": true,
    "**/sdist/": true,
    "**/var/": true,
    "**/wheels/": true,
    "**/share/python-wheels/": true,
    "**/*.egg-info/": true,
    "**/.installed.cfg": true,
    "**/*.egg": true,
    "**/MANIFEST": true,
    "**/venv/": true,
    "**/.venv/": true,
    "**/env/": true,
    "**/.env/": true,
    "**/ENV/": true,
    "**/.virtualenv/": true,
    "**/.pytest_cache/": true,
    "**/.mypy_cache/": true,
    "**/.ruff_cache/": true,
    "**/.coverage": true,
    "**/htmlcov/": true,
    "**/.tox/": true,
    "**/.nox/": true,
    "**/node_modules/": true,
    "**/jspm_packages/": true,
    "**/bower_components/": true,
    "**/dist/": true,
    "**/build/": true,
    "**/out/": true,
    "**/.next/": true,
    "**/.nuxt/": true,
    "**/.output/": true,
    "**/.cache/": true,
    "**/.parcel-cache/": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
    "**/pnpm-lock.yaml": true,
    "**/npm-debug.log*": true,
    "**/yarn-error.log*": true,
    "**/yarn-debug.log*": true,
    "**/pnpm-debug.log*": true,
    "**/*.min.js": true,
    "**/*.min.css": true,
    "**/*.map": true,
    "**/**/.terraform/": true,
    "**/*.tfstate": true,
    "**/*.tfstate.*": true,
    "**/crash.log": true,
    "**/crash.*.log": true,
    "**/*.tfvars": true,
    "**/*.tfvars.json": true,
    "**/*.jpg": true,
    "**/*.jpeg": true,
    "**/*.png": true,
    "**/*.gif": true,
    "**/*.webp": true,
    "**/*.tiff": true,
    "**/*.ico": true,
    "**/*.svg": true,
    "**/*.psd": true,
    "**/*.ai": true,
    "**/*.eps": true,
    "**/*.mp4": true,
    "**/*.m4v": true,
    "**/*.mov": true,
    "**/*.avi": true,
    "**/*.mkv": true,
    "**/*.webm": true,
    "**/*.mp3": true,
    "**/*.wav": true,
    "**/*.flac": true,
    "**/*.aac": true,
    "**/*.zip": true,
    "**/*.tar": true,
    "**/*.gz": true,
    "**/*.rar": true,
    "**/*.7z": true,
    "**/*.iso": true,
    "**/*.dmg": true,
    "**/*.pkg": true,
    "**/*.pdf": true,
    "**/*.doc": true,
    "**/*.docx": true,
    "**/*.xls": true,
    "**/*.xlsx": true,
    "**/*.ppt": true,
    "**/*.pptx": true,
    "**/*.csv": true,
    "**/*.parquet": true,
    "**/*.avro": true,
    "**/*.sqlite": true,
    "**/*.sqlite3": true,
    "**/*.db": true,
    "**/*.mdb": true,
    "**/*.exe": true,
    "**/*.dll": true,
    "**/*.dylib": true,
    "**/*.bin": true
  },

  // ============================================================================
  // Python Configuration
  // ============================================================================

  "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "python.linting.flake8Enabled": true,
  "python.formatting.provider": "black",
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnPaste": false,
    "editor.rulers": [100],
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },

  // Pylance settings
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.variableTypes": true,

  // Testing
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests",
    "--maxfail=1",
    "-v"
  ],

  // ============================================================================
  // Editor Configuration
  // ============================================================================

  "editor.formatOnSave": true,
  "editor.trimAutoWhitespace": true,
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ============================================================================
  // Git Configuration
  // ============================================================================

  "git.ignoreLimitWarning": true,

  // ============================================================================
  // Copilot Configuration
  // ============================================================================

  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true
  }
}